{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install && npm run db:generate --workspace=@bismark/api"
  },
  "deploy": {
    "startCommand": "npm run db:migrate:deploy --workspace=@bismark/api && npm run start --workspace=@bismark/api",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 120,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
