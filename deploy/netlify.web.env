# ═══════════════════════════════════════════════════════════════
# VARIABLES — FRONTEND (PWA) en NETLIFY
# Netlify → Site configuration → Environment variables → "Add a variable"
# (o pégalas en bloque con la opción de importar). Son de BUILD (Vite las hornea).
# Reemplaza lo que dice REEMPLAZA-…
# ═══════════════════════════════════════════════════════════════

# URL pública de tu API en Railway, SIN slash final.
VITE_API_URL=https://REEMPLAZA-tu-api.up.railway.app

# Dominio raíz para construir URLs públicas y detectar subdominios de riferos.
VITE_ROOT_DOMAIN=bismark.com

# Subdominios por rifero: false hasta tener tu dominio + DNS comodín en Netlify.
VITE_USE_SUBDOMAINS=false

VITE_BRAND_NAME=Bismark

# Monitoreo (Sentry) y analítica (PostHog) — opcionales. Vacío = desactivado.
VITE_SENTRY_DSN=
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Nota: el build de Netlify ya está definido en netlify.toml
#   (command: build del workspace web · publish: apps/web/dist).
# El OG dinámico (preview por rifa en WhatsApp) corre con la edge function
#   netlify/edge-functions/og.ts — necesita VITE_API_URL para llamar a /s/... de tu API.
