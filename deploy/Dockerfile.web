# Frontend (PWA Vite) para Railway. Build context = raíz del repo.
# Railway → New Service → este repo → Settings:
#   Dockerfile Path: deploy/Dockerfile.web
#
# IMPORTANTE: las variables VITE_* se "hornean" en el BUILD. Railway las inyecta
# como build-args (deben estar definidas en las Variables del servicio web).
# Si cambias VITE_API_URL, hay que volver a desplegar (rebuild) el web.

# ── Build ──────────────────────────────────────────────
FROM node:20-alpine AS build
WORKDIR /app
COPY . .
# --ignore-scripts: el web no necesita el `prisma generate` del workspace api.
RUN npm ci --ignore-scripts

ARG VITE_API_URL
ARG VITE_ROOT_DOMAIN
ARG VITE_USE_SUBDOMAINS
ARG VITE_BRAND_NAME
ARG VITE_SENTRY_DSN
ARG VITE_POSTHOG_KEY
ARG VITE_POSTHOG_HOST
ENV VITE_API_URL=$VITE_API_URL \
    VITE_ROOT_DOMAIN=$VITE_ROOT_DOMAIN \
    VITE_USE_SUBDOMAINS=$VITE_USE_SUBDOMAINS \
    VITE_BRAND_NAME=$VITE_BRAND_NAME \
    VITE_SENTRY_DSN=$VITE_SENTRY_DSN \
    VITE_POSTHOG_KEY=$VITE_POSTHOG_KEY \
    VITE_POSTHOG_HOST=$VITE_POSTHOG_HOST

RUN npm run build --workspace=@bismark/web

# ── Servir ─────────────────────────────────────────────
FROM node:20-alpine AS serve
WORKDIR /app
ENV NODE_ENV=production
ENV STATIC_DIR=/app/dist
COPY --from=build /app/apps/web/dist ./dist
COPY deploy/static-server.mjs ./static-server.mjs
EXPOSE 8080
CMD ["node", "static-server.mjs"]
