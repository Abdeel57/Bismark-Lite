# ═══════════════════════════════════════════════════════════════
# VARIABLES — SERVICIO FRONTEND (WEB / PWA)  ·  Railway → servicio "bismark-web"
# Pega esto en Variables → "Raw Editor". Reemplaza lo que dice REEMPLAZA-…
#
# ⚠️  Estas VITE_* se "hornean" en el BUILD. Si cambias VITE_API_URL después,
#     debes RE-DESPLEGAR el servicio web (rebuild) para que tome el nuevo valor.
#     (NO agregues PORT: Railway lo inyecta solo.)
# ═══════════════════════════════════════════════════════════════

# URL pública de tu API (servicio backend), SIN slash final.
VITE_API_URL=https://REEMPLAZA-tu-api.up.railway.app

# Dominio raíz para construir URLs públicas y detectar subdominios.
VITE_ROOT_DOMAIN=bismark.com

# Subdominios por rifero: false hasta tener DNS comodín en tu dominio propio.
VITE_USE_SUBDOMAINS=false

VITE_BRAND_NAME=Bismark

# Monitoreo (Sentry) y analítica (PostHog) — opcionales. Vacío = desactivado.
VITE_SENTRY_DSN=
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
