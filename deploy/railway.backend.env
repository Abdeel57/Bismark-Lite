# ═══════════════════════════════════════════════════════════════
# VARIABLES — SERVICIO BACKEND (API)  ·  Railway → servicio "bismark-api"
# Pega esto en Variables → "Raw Editor". Reemplaza lo que dice REEMPLAZA-…
# (NO agregues PORT: Railway lo inyecta solo y la app lo usa.)
# ═══════════════════════════════════════════════════════════════

NODE_ENV=production
HOST=0.0.0.0

# Base de datos: agrega el plugin PostgreSQL en Railway y referencia su URL.
# Si el plugin se llama "Postgres", esta referencia funciona tal cual:
DATABASE_URL=${{Postgres.DATABASE_URL}}

# Secretos de sesión — genera cadenas largas y aleatorias (>=32 chars).
# Tip: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=REEMPLAZA-secreto-largo-aleatorio-1
COOKIE_SECRET=REEMPLAZA-secreto-largo-aleatorio-2
JWT_EXPIRES_IN=7d

# Cookies. Front (Netlify) y API (Railway) son dominios distintos → SameSite=None.
# (Cuando uses dominios propios: web bismark.com + api api.bismark.com →
#  SAME_SITE=lax y COOKIE_DOMAIN=.bismark.com, más seguro.)
COOKIE_SECURE=true
COOKIE_SAME_SITE=none
COOKIE_DOMAIN=

# CORS / CSRF: el origen EXACTO del frontend en Netlify (sin slash final).
CORS_ORIGINS=https://REEMPLAZA-tu-sitio.netlify.app
# Comodín de subdominios propios (deja vacío con netlify.app). Ej. prod: bismark.com
CORS_ROOT_DOMAIN=

# Dominios públicos (para enlaces de boletos/QR, correos y OG).
ROOT_DOMAIN=bismark.com
USE_SUBDOMAINS=false
PUBLIC_WEB_URL=https://REEMPLAZA-tu-sitio.netlify.app
PUBLIC_API_URL=https://REEMPLAZA-tu-api.up.railway.app

# Almacenamiento: agrega un VOLUME al servicio montado en /data.
STORAGE_DRIVER=local
LOCAL_UPLOAD_DIR=/data/uploads

# Correo transaccional (opcional pero recomendado). Sin RESEND_API_KEY los
# correos solo se imprimen en logs (la app NO se rompe).
RESEND_API_KEY=
EMAIL_FROM=Bismark <no-reply@REEMPLAZA-tudominio.com>
EMAIL_REPLY_TO=
PASSWORD_RESET_TTL_MIN=60

# Monitoreo de errores (opcional). Vacío = desactivado.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0

# Credenciales del seed (cámbialas ANTES de sembrar producción).
SEED_ADMIN_EMAIL=REEMPLAZA-admin@tudominio.com
SEED_ADMIN_PASSWORD=REEMPLAZA-clave-admin-fuerte
SEED_ADMIN_NAME=Administrador Bismark
SEED_RIFERO_EMAIL=demo@tudominio.com
SEED_RIFERO_PASSWORD=REEMPLAZA-clave-demo
