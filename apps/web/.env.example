# ─────────────────────────────────────────────
# Bismark Web — variables de entorno (ejemplo)
# Copia a .env.local y ajusta.
# ─────────────────────────────────────────────

# URL base de la API.
# En desarrollo usa el proxy de Vite con "/api" (recomendado, comparte cookies).
VITE_API_URL=/api

# Dominio raíz para construir URLs públicas y detectar subdominios de riferos.
VITE_ROOT_DOMAIN=bismark.com

# ¿Usar subdominios en producción? (true en prod con DNS comodín configurado)
VITE_USE_SUBDOMAINS=false

# Nombre de la marca (por si quieres white-label en el futuro)
VITE_BRAND_NAME=Bismark

# ─────────────────────────────────────────────
# Monitoreo de errores (Sentry) — opcional. Vacío = desactivado.
# Crea un proyecto "React" en https://sentry.io y copia su DSN.
# ─────────────────────────────────────────────
VITE_SENTRY_DSN=

# ─────────────────────────────────────────────
# Analítica de producto (PostHog) — opcional. Vacío = desactivado.
# Cuenta gratis en https://posthog.com (1M eventos/mes). Copia tu Project API Key.
# Host: US = https://us.i.posthog.com  ·  EU = https://eu.i.posthog.com
# ─────────────────────────────────────────────
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
