# ─────────────────────────────────────────────
# Bismark API — variables de entorno (ejemplo)
# Copia este archivo a .env y rellena los valores.
# ─────────────────────────────────────────────

# Entorno
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# Base de datos PostgreSQL (Railway provee DATABASE_URL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bismark?schema=public"

# Seguridad
# Genera secretos largos y aleatorios (>= 32 chars). NO los compartas.
JWT_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio-min-32-chars"
COOKIE_SECRET="cambia-esto-por-otro-secreto-largo-y-aleatorio-min-32-chars"
# Vida del token de sesión
JWT_EXPIRES_IN="7d"
#
# COOKIES DE SESIÓN — configuración recomendada (web en bismark.com, API en
# api.bismark.com, mismo dominio raíz = "same-site"):
#   PRODUCCIÓN:
#     COOKIE_SECURE=true          # requiere HTTPS
#     COOKIE_SAME_SITE=lax        # same-site basta y mitiga CSRF de raíz
#     COOKIE_DOMAIN=.bismark.com  # comparte la cookie entre web y api
#   Si la API quedara en un dominio DISTINTO (ej. *.up.railway.app), tendrías
#   que usar COOKIE_SAME_SITE=none + COOKIE_SECURE=true (más superficie CSRF;
#   el guard de Origin del backend sigue protegiendo).
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_DOMAIN=

# CORS — orígenes permitidos separados por coma. La misma allowlist alimenta el
# guard CSRF (valida el header Origin en POST/PATCH/DELETE).
# En prod incluye el dominio web y el comodín de subdominios si aplica.
CORS_ORIGINS="http://localhost:5173,http://localhost:4173"
# Permitir cualquier subdominio de este dominio raíz. Vacío = desactivado.
# Ej. en prod: bismark.com  (permite app.bismark.com, <rifero>.bismark.com, …)
CORS_ROOT_DOMAIN=

# Dominios públicos (para construir URLs de boletos/QR y validar subdominios)
ROOT_DOMAIN=bismark.com
USE_SUBDOMAINS=false
PUBLIC_WEB_URL="http://localhost:5173"

# Super admin (usado por el seed)
SEED_ADMIN_EMAIL="admin@bismark.com"
SEED_ADMIN_PASSWORD="Admin1234!"
SEED_ADMIN_NAME="Super Admin Bismark"

# Rifero demo (usado por el seed)
SEED_RIFERO_EMAIL="demo@bismark.com"
SEED_RIFERO_PASSWORD="Demo1234!"

# ─────────────────────────────────────────────
# Correo transaccional (recuperación de contraseña, aviso de órdenes)
# Sin RESEND_API_KEY el driver es "log": imprime el correo en consola (dev).
# En prod: crea cuenta en https://resend.com, verifica tu dominio (SPF/DKIM)
# y usa un remitente de ese dominio en EMAIL_FROM.
# ─────────────────────────────────────────────
EMAIL_DRIVER=
RESEND_API_KEY=
EMAIL_FROM="Bismark <no-reply@bismark.com>"
EMAIL_REPLY_TO=
# Minutos de validez del enlace de recuperación
PASSWORD_RESET_TTL_MIN=60

# ─────────────────────────────────────────────
# Monitoreo de errores (Sentry) — opcional. Sin DSN no se inicializa nada.
# ─────────────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0

# ─────────────────────────────────────────────
# Almacenamiento de archivos (logos, portadas, premios, comprobantes, videos)
# Driver: "local" (también usado con Volumen de Railway) | "cloudinary" | "s3"
#
# PRODUCCIÓN (Railway): usa un VOLUMEN persistente, NO la base de datos.
#   1. En el servicio de la API agrega un Volume (ej. montado en /data).
#   2. Deja STORAGE_DRIVER=local y apunta LOCAL_UPLOAD_DIR al volumen:
#        LOCAL_UPLOAD_DIR=/data/uploads
#   Así los archivos persisten entre deploys y se sirven en /uploads/...
#   (Sin Volumen, el disco del contenedor se borra en cada deploy.)
# ─────────────────────────────────────────────
STORAGE_DRIVER=local
# Carpeta local. En dev: ./uploads. En Railway con Volume: /data/uploads
LOCAL_UPLOAD_DIR=./uploads

# Cloudinary (driver=cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=bismark

# S3 compatible (driver=s3) — AWS S3, Cloudflare R2, MinIO, etc.
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
